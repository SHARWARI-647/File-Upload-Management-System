# Flask environment: development | production
FLASK_ENV=development

# Secret key (generate a strong random value for production)
SECRET_KEY=your-super-secret-key-change-me

# Database URL (SQLite default; use Postgres on Render for persistence)
# DATABASE_URL=sqlite:///database/filemanager.db

# Default admin account (created on first run if no admin exists)
ADMIN_EMAIL=admin@filemanager.local
ADMIN_PASSWORD=change-this-admin-password

# Server port (local)
PORT=5000

# Set to true in production behind HTTPS
SESSION_COOKIE_SECURE=false
